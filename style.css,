:root {
    --bg-dark: #060713;
    --sidebar-bg: rgba(10, 11, 30, 0.75);
    --panel-bg: rgba(18, 20, 50, 0.55);
    --neon-blue: #00f2fe;
    --neon-purple: #9d4edd;
    --text-main: #e2e8f0;
    --text-muted: #707593;
    --border-color: rgba(0, 242, 254, 0.15);
    --border-glow: rgba(157, 78, 221, 0.25);
    --glass-blur: blur(20px);
    --font-orbitron: 'Orbitron', sans-serif;
    --font-poppins: 'Poppins', sans-serif;
    --transition-smooth: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: var(--font-poppins);
}

body {
    background-color: var(--bg-dark);
    color: var(--text-main);
    overflow: hidden;
    height: 100vh;
    width: 100vw;
}

/* Base Utility Classes */
.id-hidden {
    display: none !important;
}

/* Animated Neon Background */
.animated-bg {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: 0;
    overflow: hidden;
    background: radial-gradient(circle at 50% 50%, #11133c 0%, #060713 100%);
}

.cube {
    position: absolute;
    width: 80px;
    height: 80px;
    border: 1px solid rgba(0, 242, 254, 0.08);
    background: transparent;
    transform-origin: center;
    animation: cubeFloat 25s infinite linear;
    bottom: -100px;
}

.cube:nth-child(1) { left: 10%; width: 120px; height: 120px; animation-delay: 0s; animation-duration: 20s; }
.cube:nth-child(2) { left: 40%; width: 60px; height: 60px; animation-delay: 3s; animation-duration: 28s; }
.cube:nth-child(3) { left: 70%; width: 90px; height: 90px; animation-delay: 7s; }
.cube:nth-child(4) { left: 85%; width: 50px; height: 50px; animation-delay: 12s; animation-duration: 18s; }
.cube:nth-child(5) { left: 25%; width: 110px; height: 110px; animation-delay: 5s; }

@keyframes cubeFloat {
    0% { transform: translateY(0) rotate(0deg); opacity: 0; }
    10% { opacity: 0.6; }
    90% { opacity: 0.6; }
    100% { transform: translateY(-120vh) rotate(360deg); opacity: 0; }
}

/* Master Layout Grid */
.app-container {
    display: flex;
    position: relative;
    width: 100%;
    height: 100vh;
    z-index: 10;
}

/* Sidebar Styling - Glassmorphism */
.sidebar {
    width: 320px;
    height: 100%;
    background: var(--sidebar-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-right: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    padding: 24px;
    z-index: 100;
    transition: var(--transition-smooth);
}

.sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
}

.brand {
    display: flex;
    align-items: center;
    gap: 12px;
}

.brand-icon {
    font-size: 28px;
    color: var(--neon-blue);
    filter: drop-shadow(0 0 8px var(--neon-blue));
    animation: pulseGlow 3s infinite alternate;
}

.brand-text h1 {
    font-family: var(--font-orbitron);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 2px;
    background: linear-gradient(to right, var(--neon-blue), var(--neon-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.brand-text span {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 1px;
    display: block;
}

.close-sidebar-btn {
    display: none;
    background: transparent;
    border: none;
    color: var(--text-main);
    font-size: 20px;
    cursor: pointer;
}

.new-chat-btn {
    background: linear-gradient(135deg, rgba(0, 242, 254, 0.1), rgba(157, 78, 221, 0.15));
    border: 1px solid var(--neon-blue);
    color: var(--text-main);
    padding: 14px;
    border-radius: 12px;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    cursor: pointer;
    transition: var(--transition-smooth);
    font-family: var(--font-orbitron);
    letter-spacing: 1px;
    box-shadow: 0 0 15px rgba(0, 242, 254, 0.1);
}

.new-chat-btn:hover {
    box-shadow: 0 0 25px rgba(0, 242, 254, 0.35), inset 0 0 10px rgba(0, 242, 254, 0.2);
    transform: translateY(-2px);
    border-color: #fff;
}

.sidebar-nav {
    flex: 1;
    overflow-y: auto;
    margin-top: 28px;
    padding-right: 4px;
}

.sidebar-nav::-webkit-scrollbar {
    width: 4px;
}
.sidebar-nav::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 4px;
}

.section-title {
    font-size: 11px;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 2px;
    display: block;
    margin-bottom: 16px;
    font-weight: 600;
}

.chat-history-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.history-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid transparent;
    cursor: pointer;
    transition: var(--transition-smooth);
}

.history-item i {
    color: var(--text-muted);
    font-size: 15px;
    transition: var(--transition-smooth);
}

.history-text {
    flex: 1;
    margin: 0 12px;
    font-size: 13px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text-main);
}

.delete-history-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    opacity: 0;
    cursor: pointer;
    transition: var(--transition-smooth);
}

.history-item:hover {
    background: rgba(0, 242, 254, 0.05);
    border-color: rgba(0, 242, 254, 0.2);
}

.history-item:hover .delete-history-btn {
    opacity: 1;
}

.history-item.active {
    background: linear-gradient(90deg, rgba(0, 242, 254, 0.08) 0%, rgba(157, 78, 221, 0.08) 100%);
    border-color: rgba(157, 78, 221, 0.35);
}

.history-item.active i {
    color: var(--neon-blue);
}

.sidebar-footer {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.footer-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 10px;
    cursor: pointer;
    transition: var(--transition-smooth);
    color: var(--text-main);
    font-size: 14px;
}

.footer-btn:hover {
    background: rgba(255, 255, 255, 0.05);
}

.profile-section {
    display: flex;
    align-items: center;
    gap: 14px;
    background: rgba(255, 255, 255, 0.03);
    padding: 12px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
}

.user-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--neon-purple);
}

.user-info {
    display: flex;
    flex-direction: column;
}

.user-name {
    font-size: 13px;
    font-weight: 500;
}

.user-role {
    font-size: 11px;
    color: var(--neon-blue);
}

/* Chat Container Area Layout */
.chat-container {
    flex: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    background: transparent;
    position: relative;
}

/* Chat Header Styling */
.chat-header {
    height: 85px;
    background: rgba(6, 7, 19, 0.6);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    z-index: 50;
}

.header-left, .header-right {
    display: flex;
    align-items: center;
    gap: 20px;
}

.menu-btn {
    display: none;
    background: transparent;
    border: none;
    color: var(--text-main);
    font-size: 22px;
    cursor: pointer;
}

.ai-profile-header {
    display: flex;
    align-items: center;
    gap: 16px;
}

.avatar-container {
    position: relative;
    width: 48px;
    height: 48px;
}

.ai-avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--neon-blue);
    position: relative;
    z-index: 5;
}

.avatar-pulse {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--neon-blue);
    opacity: 0.4;
    z-index: 1;
    animation: pulseAvatar 2s infinite ease-out;
}

@keyframes pulseAvatar {
    0% { transform: scale(1); opacity: 0.5; }
    100% { transform: scale(1.4); opacity: 0; }
}

.ai-status-info h2 {
    font-size: 16px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
}

.gender-tag {
    font-size: 10px;
    background: rgba(157, 78, 221, 0.2);
    border: 1px solid var(--neon-purple);
    color: #dfb2ff;
    padding: 1px 6px;
    border-radius: 20px;
    font-weight: 400;
}

.status-indicator {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 2px;
}

.status-indicator .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #00ff88;
    box-shadow: 0 0 8px #00ff88;
}

.animate-flicker {
    animation: flicker 1.5s infinite alternate;
}

@keyframes flicker {
    0% { opacity: 0.4; }
    100% { opacity: 1; }
}

.status-text {
    font-size: 11px;
    color: var(--text-muted);
}

.action-icon-btn {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    width: 40px;
    height: 40px;
    border-radius: 10px;
    color: var(--text-main);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition-smooth);
}

.action-icon-btn:hover {
    background: rgba(0, 242, 254, 0.1);
    border-color: var(--neon-blue);
    color: var(--neon-blue);
}

/* Chat Screen Main Window Viewport */
.chat-window {
    flex: 1;
    overflow-y: auto;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.chat-window::-webkit-scrollbar {
    width: 6px;
}
.chat-window::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 10px;
}

/* Custom Message Elements Bubble Blueprint */
.message {
    display: flex;
    gap: 16px;
    max-width: 80%;
    animation: fadeSlideIn 0.4s cubic-bezier(0.18, 0.89, 0.32, 1.28) forwards;
}

@keyframes fadeSlideIn {
    0% { opacity: 0; transform: translateY(15px); }
    100% { opacity: 1; transform: translateY(0); }
}

.message-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
}

.message-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.message-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.message-bubble {
    padding: 16px 20px;
    border-radius: 16px;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--text-main);
    word-break: break-word;
}

.message-time {
    font-size: 10px;
    color: var(--text-muted);
    padding-left: 4px;
}

/* Specific Node Directives AI vs User */
.ai-message {
    align-self: flex-start;
}

.ai-message .message-bubble {
    background: var(--panel-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-top-left-radius: 4px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.user-message {
    align-self: flex-end;
    flex-direction: row-reverse;
}

.user-message .message-bubble {
    background: linear-gradient(135deg, rgba(0, 242, 254, 0.15) 0%, rgba(157, 78, 221, 0.2) 100%);
    backdrop-filter: var(--glass-blur);
    border: 1px solid rgba(0, 242, 254, 0.25);
    border-top-right-radius: 4px;
    box-shadow: 0 10px 30px rgba(0, 242, 254, 0.05);
}

/* Embedded Media Assets */
.attached-image {
    max-width: 280px;
    border-radius: 10px;
    margin-bottom: 8px;
    border: 1px solid var(--border-color);
}

/* Embedded Block Markup Elements (Code Highlight block UI) */
.code-container {
    margin-top: 12px;
    background: #02030a;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
}

.code-header {
    background: rgba(255, 255, 255, 0.03);
    padding: 8px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.code-lang {
    font-size: 11px;
    font-family: var(--font-orbitron);
    color: var(--neon-blue);
    text-transform: uppercase;
}

.copy-code-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 12px;
    transition: var(--transition-smooth);
    display: flex;
    align-items: center;
    gap: 4px;
}

.copy-code-btn:hover {
    color: var(--text-main);
}

.code-block {
    padding: 16px;
    overflow-x: auto;
    font-family: 'Courier New', Courier, monospace;
    font-size: 13.5px;
    color: #7ce5ff;
    white-space: pre;
}

/* Complex Dynamic State Loaders (Thinking, Typing Animations) */
.thinking-container {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--neon-blue);
    font-size: 12px;
    font-family: var(--font-orbitron);
    letter-spacing: 1px;
    margin-bottom: 8px;
}

.thinking-container i {
    animation: rotateMatrix 2s infinite linear;
}

@keyframes rotateMatrix {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.typing-animation {
    display: flex;
    gap: 5px;
    padding: 6px 0;
}

.typing-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--neon-blue);
    opacity: 0.3;
    animation: typingPulse 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typingPulse {
    0%, 100% { transform: translateY(0); opacity: 0.3; }
    50% { transform: translateY(-6px); opacity: 1; }
}

/* Input Form Controls Styling Matrix Core */
.chat-input-area {
    padding: 24px 32px 32px;
    background: linear-gradient(to top, var(--bg-dark) 70%, transparent);
    position: relative;
    z-index: 40;
}

.file-preview-bar {
    background: rgba(10, 11, 30, 0.9);
    border: 1px solid var(--border-color);
    padding: 10px 16px;
    border-radius: 10px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    animation: fadeSlideIn 0.3s ease;
}

.preview-item {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
}

.preview-item i {
    color: var(--neon-blue);
}

.preview-item span {
    font-size: 12px;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

#removeFileBtn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    transition: var(--transition-smooth);
}

#removeFileBtn:hover {
    color: #ff4a4a;
}

.input-wrapper {
    background: var(--panel-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4), inset 0 0 15px rgba(0, 242, 254, 0.03);
    transition: var(--transition-smooth);
}

.input-wrapper:focus-within {
    border-color: var(--neon-purple);
    box-shadow: 0 0 25px rgba(157, 78, 221, 0.25);
}

.input-actions-left, .input-actions-right {
    display: flex;
    align-items: center;
    gap: 4px;
}

.action-btn {
    background: transparent;
    border: none;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition-smooth);
    font-size: 16px;
}

.action-btn:hover {
    color: var(--neon-blue);
    background: rgba(0, 242, 254, 0.05);
}

.input-wrapper textarea {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text-main);
    font-size: 14.5px;
    resize: none;
    max-height: 180px;
    padding: 8px 0;
    line-height: 1.5;
}

.input-wrapper textarea::placeholder {
    color: var(--text-muted);
}

.voice-btn.recording {
    color: #ff4a4a;
    background: rgba(255, 74, 74, 0.1);
    animation: pulseRecording 1.5s infinite alternate;
}

@keyframes pulseRecording {
    0% { box-shadow: 0 0 0px rgba(255, 74, 74, 0); }
    100% { box-shadow: 0 0 12px rgba(255, 74, 74, 0.5); }
}

.send-btn {
    background: linear-gradient(135deg, var(--neon-blue), var(--neon-purple));
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition-smooth);
    box-shadow: 0 4px 15px rgba(0, 242, 254, 0.3);
}

.send-btn:hover {
    transform: scale(1.05) rotate(-5deg);
    box-shadow: 0 4px 25px rgba(157, 78, 221, 0.5);
}

/* Modals System Core Configuration Overlay */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(4, 5, 15, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
    from { opacity: 0; } to { opacity: 1; }
}

.modal-content {
    width: 90%;
    max-width: 480px;
    background: var(--panel-bg);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 28px;
    box-shadow: 0 20px 50px rgba(0, 242, 254, 0.1);
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
}

.modal-header h3 {
    font-family: var(--font-orbitron);
    font-size: 16px;
    color: var(--neon-blue);
    letter-spacing: 1px;
}

.close-modal-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 18px;
    cursor: pointer;
    transition: var(--transition-smooth);
}

.close-modal-btn:hover { color: #fff; }

.setting-group {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.setting-group label {
    font-size: 14px;
    color: var(--text-main);
}

/* Custom Standard Controls Inside Config */
.toggle-switch {
    position: relative;
    width: 48px;
    height: 24px;
}

.toggle-switch input { display: none; }
.toggle-switch label {
    display: block;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50px;
    cursor: pointer;
    position: relative;
    transition: var(--transition-smooth);
    border: 1px solid rgba(255, 255, 255, 0.05);
}

.toggle-switch label::after {
    content: '';
    position: absolute;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #fff;
    top: 2px;
    left: 2px;
    transition: var(--transition-smooth);
}

.toggle-switch input:checked + label {
    background: var(--neon-blue);
}

.toggle-switch input:checked + label::after {
    left: 26px;
}

.custom-select {
    background: #0b0c1e;
    border: 1px solid var(--border-color);
    color: var(--text-main);
    padding: 8px 12px;
    border-radius: 8px;
    outline: none;
    font-size: 13px;
}

.theme-dots {
    display: flex;
    gap: 10px;
}

.theme-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid transparent;
}

.theme-dot.active-dot {
    border-color: #fff;
}

/* Splash Screen Startup Loader Container */
.app-loader {
    position: fixed;
    width: 100vw;
    height: 100vh;
    background: #04050f;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    transition: opacity 0.6s ease;
}

.cyber-spinner {
    position: relative;
    width: 120px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.spinner-ring {
    position: absolute;
    border-radius: 50%;
    border: 2px solid transparent;
}

.ring-1 {
    width: 100%;
    height: 100%;
    border-top-color: var(--neon-blue);
    border-bottom-color: var(--neon-blue);
    animation: rotateRing1 1.5s infinite linear;
}

.ring-2 {
    width: 80%;
    height: 80%;
    border-left-color: var(--neon-purple);
    border-right-color: var(--neon-purple);
    animation: rotateRing2 2s infinite linear;
}

.ring-3 {
    width: 60%;
    height: 60%;
    border-top-color: #fff;
    animation: rotateRing1 1s infinite linear;
}

.loader-logo {
    font-size: 24px;
    color: var(--neon-blue);
    filter: drop-shadow(0 0 10px var(--neon-blue));
}

@keyframes rotateRing1 {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

@keyframes rotateRing2 {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(-360deg); }
}

.loader-text {
    font-family: var(--font-orbitron);
    font-size: 12px;
    letter-spacing: 3px;
    color: var(--text-muted);
    animation: textPulse 1.5s infinite alternate;
}

@keyframes textPulse {
    0% { opacity: 0.4; color: var(--text-muted); }
    100% { opacity: 1; color: var(--neon-blue); filter: drop-shadow(0 0 8px var(--neon-blue)); }
}

/* Responsive Structural Breakpoints System Matrix */
@media (max-width: 992px) {
    .sidebar {
        position: absolute;
        left: -320px;
        top: 0;
        bottom: 0;
    }
    .sidebar.open {
        left: 0;
        box-shadow: 20px 0 50px rgba(0,0,0,0.6);
    }
    .menu-btn, .close-sidebar-btn {
        display: block;
    }
}

@media (max-width: 576px) {
    .chat-header {
        padding: 0 16px;
    }
    .chat-window {
        padding: 16px;
    }
    .chat-input-area {
        padding: 16px;
    }
    .message {
        max-width: 90%;
    }
    .action-btn {
        width: 32px;
        height: 32px;
        font-size: 14px;
    }
    .input-wrapper {
        padding: 8px 12px;
    }
    .ai-status-info h2 {
        font-size: 14px;
    }
    .status-text {
        font-size: 10px;
    }
}

